#!/bin/bash
# Git post-receive hook — deploy batch-inference on push to the Droplet.
# Installed into: /opt/batch-inference.git/hooks/post-receive
set -euo pipefail

REPO_NAME="batch-inference"
WORK_TREE="${DEPLOY_WORK_TREE:-/opt/${REPO_NAME}}"
BARE_REPO="${DEPLOY_BARE_REPO:-/opt/${REPO_NAME}.git}"
BRANCH_MAIN="refs/heads/master"
BRANCH_ALT="refs/heads/main"

deploy_ref=""
while read -r _oldrev newrev refname; do
  if [ "$refname" = "$BRANCH_MAIN" ] || [ "$refname" = "$BRANCH_ALT" ]; then
    if [ "$newrev" != "0000000000000000000000000000000000000000" ]; then
      deploy_ref="$refname"
    fi
  fi
done

if [ -z "$deploy_ref" ]; then
  echo "post-receive: no master/main update — skipping deploy"
  exit 0
fi

echo "post-receive: deploying ${deploy_ref} → ${WORK_TREE}"

# Avoid "dubious ownership" when the hook user differs from the work-tree owner.
git config --global --add safe.directory "$WORK_TREE"
git config --global --add safe.directory "$BARE_REPO"

mkdir -p "$WORK_TREE"
GIT_WORK_TREE="$WORK_TREE" GIT_DIR="$BARE_REPO" git checkout -f "${deploy_ref#refs/heads/}"

cd "$WORK_TREE"

if [ ! -f .env ]; then
  echo "WARN: ${WORK_TREE}/.env missing — copy from your secrets before first boot"
fi

GIT_SHA="$(GIT_WORK_TREE="$WORK_TREE" GIT_DIR="$BARE_REPO" git rev-parse --short HEAD)"
BUILD_ID="$(GIT_WORK_TREE="$WORK_TREE" GIT_DIR="$BARE_REPO" git rev-parse HEAD)"
BUILT_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

upsert_env() {
  local key="$1" val="$2"
  if [ ! -f .env ]; then
    return 0
  fi
  if grep -q "^${key}=" .env; then
    sed -i "s|^${key}=.*|${key}=${val}|" .env
  else
    echo "${key}=${val}" >> .env
  fi
}

upsert_env GIT_SHA "$GIT_SHA"
upsert_env BUILD_ID "$BUILD_ID"
upsert_env BUILT_AT "$BUILT_AT"
export GIT_SHA BUILD_ID BUILT_AT

if command -v docker >/dev/null 2>&1; then
  echo "post-receive: docker compose up --build -d (GIT_SHA=${GIT_SHA})"
  docker compose up --build -d
  docker compose ps
  curl -sf http://127.0.0.1:8000/health || true
  echo
else
  echo "post-receive: docker not found — install Docker or start services manually"
  exit 1
fi

echo "post-receive: deploy complete"
